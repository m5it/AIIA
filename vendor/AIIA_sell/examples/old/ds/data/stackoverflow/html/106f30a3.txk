<div class="answercell post-layout--right">
        <div class="js-endorsements" data-for-answer="2146773">
</div>

    
    <div class="s-prose js-post-body" itemprop="text">
<p>Try this function </p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">objSort</span>(<span class="hljs-params">&amp;<span class="hljs-variable">$objArray</span>,<span class="hljs-variable">$indexFunction</span>,<span class="hljs-variable">$sort_flags</span>=<span class="hljs-number">0</span></span>) </span>{
    <span class="hljs-variable">$indices</span> = <span class="hljs-keyword">array</span>();
    <span class="hljs-keyword">foreach</span>(<span class="hljs-variable">$objArray</span> <span class="hljs-keyword">as</span> <span class="hljs-variable">$obj</span>) {
        <span class="hljs-variable">$indeces</span>[] = <span class="hljs-variable">$indexFunction</span>(<span class="hljs-variable">$obj</span>);
    }
    <span class="hljs-keyword">return</span> <span class="hljs-title function_ invoke__">array_multisort</span>(<span class="hljs-variable">$indeces</span>,<span class="hljs-variable">$objArray</span>,<span class="hljs-variable">$sort_flags</span>);
}
</code></pre>
