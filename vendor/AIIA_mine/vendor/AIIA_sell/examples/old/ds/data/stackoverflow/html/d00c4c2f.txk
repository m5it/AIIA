                            [next_week] =&gt; <span class="hljs-number">3</span>
                            [occurrence_date] =&gt; <span class="hljs-number">1350853200</span>
                        )

                )

            [times_list] =&gt; <span class="hljs-title function_ invoke__">Array</span>
                (
                    [<span class="hljs-number">0</span>] =&gt; Oct <span class="hljs-number">21</span> sun <span class="hljs-number">4</span>:<span class="hljs-number">00</span>pm
                )

