    <div class="s-prose js-post-body" itemprop="text">
<p>A simple <a href="http://php.net/manual/en/function.usort.php" rel="nofollow"><code>usort</code></a> will do the job.</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-variable">$arrData</span> = <span class="hljs-keyword">array</span>(<span class="hljs-comment">/* ... */</span>);
<span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$arrData</span>, function(<span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span>) {
    <span class="hljs-keyword">return</span> <span class="hljs-variable">$a</span>-&gt;score &lt; <span class="hljs-variable">$b</span>-&gt;score ? <span class="hljs-number">1</span> : -<span class="hljs-number">1</span>;
});
</code></pre>
    </div>
