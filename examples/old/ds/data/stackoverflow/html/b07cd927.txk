    <a class="js-post-issue flex--item s-btn s-btn__unset c-pointer py6 mx-auto" href="/posts/1319936/timeline" data-shortcut="T" data-ks-title="timeline" data-controller="s-tooltip" data-s-tooltip-placement="right" aria-label="Timeline" aria-describedby="--stacks-s-tooltip-6n4ccktj"><svg aria-hidden="true" class="mln2 mr0 svg-icon iconHistory" width="19" height="18" viewbox="0 0 19 18"><path d="M3 9a8 8 0 1 1 3.73 6.77L8.2 14.3A6 6 0 1 0 5 9l3.01-.01-4 4-4-4zm7-4h1.01L11 9.36l3.22 2.1-.6.93L10 10z"/></svg></a><div id="--stacks-s-tooltip-6n4ccktj" class="s-popover s-popover__tooltip" role="tooltip">Show activity on this post.<div class="s-popover--arrow"/></div>

</div>

            </div>

            

<div class="answercell post-layout--right">
        <div class="js-endorsements" data-for-answer="1319936">
</div>

    
    <div class="s-prose js-post-body" itemprop="text">
<p>For php &gt;= 5.3</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">osort</span>(<span class="hljs-params">&amp;<span class="hljs-variable">$array</span>, <span class="hljs-variable">$prop</span></span>)
</span>{
    <span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$array</span>, function(<span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span>) <span class="hljs-keyword">use</span> ($<span class="hljs-title">prop</span>) {
        <span class="hljs-title">return</span> $<span class="hljs-title">a</span>-&gt;$<span class="hljs-title">prop</span> &gt; $<span class="hljs-title">b</span>-&gt;$<span class="hljs-title">prop</span> ? 1 : -1;
    }); 
}
</code></pre>

<p>Note that this uses Anonymous functions / closures. Might find reviewing the php docs on that useful.</p>
    </div>
