<div class="answercell post-layout--right">
    
    <div class="s-prose js-post-body" itemprop="text">
<p>Another variation of <code>std::visit</code> based dispatch, this time we assume that the enums are a contiguous range, or that gaps are uncommon enough to not be problematic, code-size wise.</p>
<pre class="lang-cpp s-code-block"><code data-highlighted="yes" class="hljs language-cpp"><span class="hljs-keyword">namespace</span> detail {
<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-keyword">struct</span> <span class="hljs-title class_">enum_range</span>;

<span class="hljs-keyword">template</span>&lt;&gt;
<span class="hljs-keyword">struct</span> <span class="hljs-title class_">enum_range</span>&lt;Color&gt; 
{
    <span class="hljs-type">static</span> <span class="hljs-keyword">constexpr</span> Color min = Color::Red;
    <span class="hljs-type">static</span> <span class="hljs-keyword">constexpr</span> Color max = Color::Blue;
};

<span class="hljs-keyword">template</span>&lt;&gt;
<span class="hljs-keyword">struct</span> <span class="hljs-title class_">enum_range</span>&lt;Type&gt; 
{
    <span class="hljs-type">static</span> <span class="hljs-keyword">constexpr</span> Type min = Type::Car;
    <span class="hljs-type">static</span> <span class="hljs-keyword">constexpr</span> Type max = Type::Truck;
};

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-function">std::<span class="hljs-type">size_t</span> <span class="hljs-title">to_index</span><span class="hljs-params">(E Value)</span>
</span>{
    <span class="hljs-keyword">return</span> <span class="hljs-built_in">static_cast</span>&lt;std::<span class="hljs-type">size_t</span>&gt;(Value) - <span class="hljs-built_in">static_cast</span>&lt;std::<span class="hljs-type">size_t</span>&gt;(enum_range&lt;E&gt;::min);
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E, E Value&gt;
<span class="hljs-function"><span class="hljs-keyword">constexpr</span> std::<span class="hljs-type">size_t</span> <span class="hljs-title">to_size</span><span class="hljs-params">()</span>
</span>{
    <span class="hljs-keyword">return</span> <span class="hljs-built_in">static_cast</span>&lt;std::<span class="hljs-type">size_t</span>&gt;(Value) - <span class="hljs-built_in">static_cast</span>&lt;std::<span class="hljs-type">size_t</span>&gt;(enum_range&lt;E&gt;::min);
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E, std::<span class="hljs-type">size_t</span> Value&gt;
<span class="hljs-function"><span class="hljs-keyword">constexpr</span> E <span class="hljs-title">from_size</span><span class="hljs-params">()</span>
</span>{
    <span class="hljs-keyword">return</span> <span class="hljs-built_in">static_cast</span>&lt;E&gt;(Value + <span class="hljs-built_in">static_cast</span>&lt;std::<span class="hljs-type">size_t</span>&gt;(enum_range&lt;E&gt;::min));
}

<span class="hljs-function"><span class="hljs-keyword">template</span>&lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-keyword">constexpr</span> std::<span class="hljs-type">size_t</span> <span class="hljs-title">enum_size</span><span class="hljs-params">()</span>
</span>{
    <span class="hljs-keyword">return</span> to_size&lt;E, enum_range&lt;E&gt;::max&gt;() + <span class="hljs-number">1</span>;
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-keyword">using</span> indices = std::make_index_sequence&lt;<span class="hljs-built_in">enum_size</span>&lt;E&gt;()&gt;;

<span class="hljs-keyword">template</span>&lt;<span class="hljs-keyword">typename</span> E, std::<span class="hljs-type">size_t</span>... Is&gt;
std::variant&lt;std::integral_constant&lt;E, from_size&lt;E, Is&gt;()&gt;...&gt; <span class="hljs-built_in">make_variant</span>(std::index_sequence&lt;Is...&gt;)
{
    <span class="hljs-keyword">return</span> {}; 
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-keyword">using</span> enum_variant = <span class="hljs-keyword">decltype</span>(<span class="hljs-built_in">make_variant</span>&lt;E&gt;(indices&lt;E&gt;{}));

<span class="hljs-keyword">template</span>&lt;<span class="hljs-keyword">typename</span> E, std::<span class="hljs-type">size_t</span>... Is&gt;
std::array&lt;enum_variant&lt;E&gt;, <span class="hljs-built_in">enum_size</span>&lt;E&gt;()&gt; <span class="hljs-built_in">make_array</span>(std::index_sequence&lt;Is...&gt;)
{
    <span class="hljs-keyword">return</span> { std::integral_constant&lt;E, <span class="hljs-built_in">from_size</span>&lt;E, Is&gt;()&gt;{}... };
}
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-function">detail::enum_variant&lt;E&gt; <span class="hljs-title">select</span><span class="hljs-params">(E value)</span>
</span>{
    <span class="hljs-type">static</span> <span class="hljs-type">const</span> <span class="hljs-keyword">auto</span> enum_array = detail::<span class="hljs-built_in">make_array</span>&lt;E&gt;(detail::indices&lt;E&gt;{});
    <span class="hljs-keyword">return</span> enum_array[detail::<span class="hljs-built_in">to_index</span>(value)];
}

<span class="hljs-function"><span class="hljs-type">int</span> <span class="hljs-title">main</span><span class="hljs-params">()</span>
</span>{
    Vehicle v { Color::Blue, Type::Bus };

    <span class="hljs-keyword">auto</span> func = [&amp;] &lt;Color color, Type type&gt; {
             <span class="hljs-keyword">if</span> <span class="hljs-built_in">constexpr</span> (color == Color::Red)   { std::cout &lt;&lt; <span class="hljs-string">"Red "</span>;   }
        <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> <span class="hljs-built_in">constexpr</span> (color == Color::Green) { std::cout &lt;&lt; <span class="hljs-string">"Green "</span>; }
        <span class="hljs-keyword">else</span>                                      { std::cout &lt;&lt; <span class="hljs-string">"Blue "</span>;  }

             <span class="hljs-function"><span class="hljs-keyword">if</span> <span class="hljs-title">constexpr</span> <span class="hljs-params">(type == Type::Car)</span> </span>{ std::cout &lt;&lt; <span class="hljs-string">"Car"</span>;   }
        <span class="hljs-keyword">else</span> <span class="hljs-keyword">if</span> <span class="hljs-built_in">constexpr</span> (type == Type::Bus) { std::cout &lt;&lt; <span class="hljs-string">"Bus"</span>;   }
        <span class="hljs-keyword">else</span>                                  { std::cout &lt;&lt; <span class="hljs-string">"Truck"</span>; }
    };

    <span class="hljs-comment">// Now, we can use the std::visit with as many enum values as we want.</span>
    <span class="hljs-comment">// Each value is wrapped by a call to select</span>
    std::<span class="hljs-built_in">visit</span>([&amp;](<span class="hljs-keyword">auto</span>...args) {
        func.<span class="hljs-keyword">template</span> <span class="hljs-built_in">operator</span>()&lt;args...&gt; ();
    }, <span class="hljs-built_in">select</span>(v.color), <span class="hljs-built_in">select</span>(v.type));
}
</code></pre>
<p>This can be greatly simplified with the library <a href="https://github.com/Neargye/magic_enum/tree/master" rel="nofollow noreferrer">magic_enum</a>, which also resolves the issue of non-contiguous enumerators</p>
<pre class="lang-cpp s-code-block"><code data-highlighted="yes" class="hljs language-cpp"><span class="hljs-keyword">namespace</span> detail {
<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-keyword">using</span> indices = std::make_index_sequence&lt;magic_enum::<span class="hljs-built_in">enum_count</span>&lt;E&gt;()&gt;;

<span class="hljs-keyword">template</span>&lt;<span class="hljs-keyword">typename</span> E, std::<span class="hljs-type">size_t</span>... Is&gt;
std::variant&lt;std::integral_constant&lt;E, magic_enum::enum_value&lt;E, Is&gt;()&gt;...&gt; <span class="hljs-built_in">make_variant</span>(std::index_sequence&lt;Is...&gt;)
{
    <span class="hljs-keyword">return</span> {}; 
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-keyword">using</span> enum_variant = <span class="hljs-keyword">decltype</span>(<span class="hljs-built_in">make_variant</span>&lt;E&gt;(indices&lt;E&gt;{}));

<span class="hljs-keyword">template</span>&lt;<span class="hljs-keyword">typename</span> E, std::<span class="hljs-type">size_t</span>... Is&gt;
std::array&lt;enum_variant&lt;E&gt;, magic_enum::<span class="hljs-built_in">enum_count</span>&lt;E&gt;()&gt; <span class="hljs-built_in">make_array</span>(std::index_sequence&lt;Is...&gt;)
{
    <span class="hljs-keyword">return</span> { std::integral_constant&lt;E, magic_enum::<span class="hljs-built_in">enum_value</span>&lt;E, Is&gt;()&gt;{}... };
}
}

<span class="hljs-keyword">template</span> &lt;<span class="hljs-keyword">typename</span> E&gt;
<span class="hljs-function">detail::enum_variant&lt;E&gt; <span class="hljs-title">select</span><span class="hljs-params">(E value)</span>
</span>{
    <span class="hljs-type">static</span> <span class="hljs-type">const</span> <span class="hljs-keyword">auto</span> enum_array = detail::<span class="hljs-built_in">make_array</span>&lt;E&gt;(detail::indices&lt;E&gt;{});
    <span class="hljs-keyword">return</span> enum_array[magic_enum::<span class="hljs-built_in">enum_index</span>(value).<span class="hljs-built_in">value_or</span>(<span class="hljs-number">0</span>)];
}
</code></pre>
    </div>
    <div class="mt24">
        <div class="d-flex fw-wrap ai-start jc-end gs8 gsy">
            <time itemprop="dateCreated" datetime="2025-05-28 10:57:48Z"/>
            <div class="flex--item mr16" style="flex: 1 1 100px;">
                


<div class="js-post-menu pt2" data-post-id="79642059" data-post-type-id="2">

