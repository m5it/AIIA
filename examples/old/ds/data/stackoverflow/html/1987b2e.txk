    <li id="comment-6343690" class="comment js-comment " data-comment-id="6343690" data-comment-owner-id="415763" data-comment-score="0">
        <div class="js-comment-actions comment-actions">
            <div class="comment-score js-comment-score js-comment-edit-hide">
