    <div class="s-prose js-post-body" itemprop="text">
<p>Try usort: <a href="http://www.php.net/manual/en/function.usort.php" rel="nofollow">http://www.php.net/manual/en/function.usort.php</a></p>

<p>Example:</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-meta">&lt;?php</span>
<span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">cmp</span>(<span class="hljs-params"><span class="hljs-variable">$obja</span>, <span class="hljs-variable">$objb</span></span>)
</span>{
    <span class="hljs-variable">$a</span> = <span class="hljs-variable">$obja</span>-&gt;sortField;
    <span class="hljs-variable">$b</span> = <span class="hljs-variable">$objb</span>-&gt;sortField;
    <span class="hljs-keyword">if</span> (<span class="hljs-variable">$a</span> == <span class="hljs-variable">$b</span>) {
        <span class="hljs-keyword">return</span> <span class="hljs-number">0</span>;
    }
    <span class="hljs-keyword">return</span> (<span class="hljs-variable">$a</span> &lt; <span class="hljs-variable">$b</span>) ? -<span class="hljs-number">1</span> : <span class="hljs-number">1</span>;
}

<span class="hljs-variable">$a</span> = <span class="hljs-keyword">array</span>( <span class="hljs-comment">/* your objects */</span> );

<span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$a</span>, <span class="hljs-string">"cmp"</span>);

<span class="hljs-meta">?&gt;</span>
</code></pre>
    </div>
