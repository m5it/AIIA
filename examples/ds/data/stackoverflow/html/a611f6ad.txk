    <div class="s-prose js-post-body" itemprop="text">
<p>This is what I have for a utility class</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">Util</span>
</span>{
    <span class="hljs-keyword">public</span> <span class="hljs-built_in">static</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">sortArrayByName</span>(<span class="hljs-params">&amp;<span class="hljs-variable">$arrayToSort</span>, <span class="hljs-variable">$meta</span></span>) </span>{
        <span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$arrayToSort</span>, function(<span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span>) <span class="hljs-keyword">use</span> ($<span class="hljs-title">meta</span>) {
            <span class="hljs-title">return</span> <span class="hljs-title">strcmp</span>($<span class="hljs-title">a</span>[$<span class="hljs-title">meta</span>], $<span class="hljs-title">b</span>[$<span class="hljs-title">meta</span>]);
        });
    }
}
</code></pre>

<p><strong>Call it:</strong></p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-title class_">Util</span>::<span class="hljs-title function_ invoke__">sortArrayByName</span>(<span class="hljs-variable">$array</span>, <span class="hljs-string">"array_property_name"</span>);
</code></pre>
    </div>
