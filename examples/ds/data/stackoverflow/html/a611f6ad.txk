    <div class="s-prose js-post-body" itemprop="text">
<p>if you want to sort dates</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php">   <span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$threads</span>,function(<span class="hljs-variable">$first</span>,<span class="hljs-variable">$second</span>){
        <span class="hljs-keyword">return</span> <span class="hljs-title function_ invoke__">strtotime</span>(<span class="hljs-variable">$first</span>-&gt;dateandtime) &lt; <span class="hljs-title function_ invoke__">strtotime</span>(<span class="hljs-variable">$second</span>-&gt;dateandtime);
    });
</code></pre>
    </div>
