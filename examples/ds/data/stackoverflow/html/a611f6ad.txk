    <div class="s-prose js-post-body" itemprop="text">
<p>if you're using php oop you might need to change to:</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-keyword">public</span> <span class="hljs-built_in">static</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">cmp</span>(<span class="hljs-params"><span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span></span>) 
</span>{
    <span class="hljs-keyword">return</span> <span class="hljs-title function_ invoke__">strcmp</span>(<span class="hljs-variable">$a</span>-&gt;name, <span class="hljs-variable">$b</span>-&gt;name);
}

<span class="hljs-comment">//in this case FUNCTION_NAME would be cmp</span>
<span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$your_data</span>, <span class="hljs-keyword">array</span>(<span class="hljs-string">'YOUR_CLASS_NAME'</span>,<span class="hljs-string">'FUNCTION_NAME'</span>)); 
</code></pre>
    </div>
