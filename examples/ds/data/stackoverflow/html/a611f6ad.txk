    <div class="s-prose js-post-body" itemprop="text">
<p>If everything fails here is another solution:</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-variable">$names</span> = <span class="hljs-keyword">array</span>(); 
<span class="hljs-keyword">foreach</span> (<span class="hljs-variable">$my_array</span> <span class="hljs-keyword">as</span> <span class="hljs-variable">$my_object</span>) {
    <span class="hljs-variable">$names</span>[] = <span class="hljs-variable">$my_object</span>-&gt;name; <span class="hljs-comment">//any object field</span>
}

<span class="hljs-title function_ invoke__">array_multisort</span>(<span class="hljs-variable">$names</span>, SORT_ASC, <span class="hljs-variable">$my_array</span>);

<span class="hljs-keyword">return</span> <span class="hljs-variable">$my_array</span>;
</code></pre>
    </div>
