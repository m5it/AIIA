<div class="answercell post-layout--right">
        <div class="js-endorsements" data-for-answer="56862445">
</div>

    
    <div class="s-prose js-post-body" itemprop="text">
<p><em>You can use usort like this</em></p>

<p><strong>If you want to sort by number:</strong></p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">cmp</span>(<span class="hljs-params"><span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span></span>)
</span>{
    <span class="hljs-keyword">if</span> (<span class="hljs-variable">$a</span> == <span class="hljs-variable">$b</span>) {
        <span class="hljs-keyword">return</span> <span class="hljs-number">0</span>;
    }
    <span class="hljs-keyword">return</span> (<span class="hljs-variable">$a</span> &lt; <span class="hljs-variable">$b</span>) ? -<span class="hljs-number">1</span> : <span class="hljs-number">1</span>;
}

<span class="hljs-variable">$a</span> = <span class="hljs-keyword">array</span>(<span class="hljs-number">3</span>, <span class="hljs-number">2</span>, <span class="hljs-number">5</span>, <span class="hljs-number">6</span>, <span class="hljs-number">1</span>);

<span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$a</span>, <span class="hljs-string">"cmp"</span>);
</code></pre>

<p><strong>Or Abc char:</strong></p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">cmp</span>(<span class="hljs-params"><span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span></span>)
</span>{
    <span class="hljs-keyword">return</span> <span class="hljs-title function_ invoke__">strcmp</span>(<span class="hljs-variable">$a</span>[<span class="hljs-string">"fruit"</span>], <span class="hljs-variable">$b</span>[<span class="hljs-string">"fruit"</span>]);
}

<span class="hljs-variable">$fruits</span>[<span class="hljs-number">0</span>][<span class="hljs-string">"fruit"</span>] = <span class="hljs-string">"lemons"</span>;
<span class="hljs-variable">$fruits</span>[<span class="hljs-number">1</span>][<span class="hljs-string">"fruit"</span>] = <span class="hljs-string">"apples"</span>;
<span class="hljs-variable">$fruits</span>[<span class="hljs-number">2</span>][<span class="hljs-string">"fruit"</span>] = <span class="hljs-string">"grapes"</span>;

<span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$fruits</span>, <span class="hljs-string">"cmp"</span>);
</code></pre>

<p>See more: <a href="https://www.php.net/manual/en/function.usort.php" rel="nofollow noreferrer">https://www.php.net/manual/en/function.usort.php</a></p>
    </div>
