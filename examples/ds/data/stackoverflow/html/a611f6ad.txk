    <div class="s-prose js-post-body" itemprop="text">
<p>use this....</p>
<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-variable">$array_list</span> = [
    <span class="hljs-string">"Apple"</span> =&gt; <span class="hljs-number">2</span>,
    <span class="hljs-string">"Pear"</span> =&gt; <span class="hljs-number">1</span>,
    <span class="hljs-string">"Orange"</span> =&gt; <span class="hljs-number">5</span>,
    <span class="hljs-string">"Lemon"</span> =&gt; <span class="hljs-number">1</span>,
    <span class="hljs-string">"Strawberry"</span> =&gt; <span class="hljs-number">2</span>,
    <span class="hljs-string">"Banana"</span> =&gt; <span class="hljs-number">3</span>
];

<span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">cmp</span>(<span class="hljs-params"><span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span></span>) </span>{
    <span class="hljs-keyword">return</span> <span class="hljs-variable">$b</span> - <span class="hljs-variable">$a</span>;
}

<span class="hljs-variable">$ao</span> = <span class="hljs-keyword">new</span> <span class="hljs-built_in">ArrayObject</span>(<span class="hljs-variable">$object</span>);
<span class="hljs-variable">$ao</span>-&gt;<span class="hljs-title function_ invoke__">uasort</span>(<span class="hljs-string">'cmp'</span>);
<span class="hljs-title function_ invoke__">print_r</span>(<span class="hljs-title function_ invoke__">json_encode</span>(<span class="hljs-variable">$ao</span>));
</code></pre>
<p>Bye!!!!</p>
