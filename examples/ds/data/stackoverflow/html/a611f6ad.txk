    <div class="s-prose js-post-body" itemprop="text">
<p>reference answer of Demodave to eating multi key</p>
<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">array_sort_by</span>(<span class="hljs-params"><span class="hljs-keyword">array</span> <span class="hljs-variable">$arr</span>, <span class="hljs-variable">$keys</span></span>)</span>{

    <span class="hljs-keyword">if</span>(!<span class="hljs-title function_ invoke__">is_array</span>(<span class="hljs-variable">$keys</span>))
        <span class="hljs-variable">$keyList</span> = <span class="hljs-title function_ invoke__">explode</span>(<span class="hljs-string">','</span>, <span class="hljs-variable">$keys</span>);
    <span class="hljs-variable">$keyList</span> = <span class="hljs-title function_ invoke__">array_keys</span>(<span class="hljs-title function_ invoke__">array_flip</span>(<span class="hljs-variable">$keyList</span>)); <span class="hljs-comment">// array_unique </span>
    <span class="hljs-variable">$keyList</span> = <span class="hljs-title function_ invoke__">array_reverse</span>(<span class="hljs-variable">$keyList</span>);

    <span class="hljs-variable">$result</span> = &amp;<span class="hljs-variable">$arr</span>;
    <span class="hljs-keyword">foreach</span> (<span class="hljs-variable">$keyList</span> <span class="hljs-keyword">as</span> <span class="hljs-variable">$key</span>) {
        <span class="hljs-keyword">if</span>(<span class="hljs-title function_ invoke__">array_key_exists</span>(<span class="hljs-variable">$key</span>, <span class="hljs-variable">$arr</span>))
            <span class="hljs-variable">$result</span> = <span class="hljs-title function_ invoke__">usort</span>(<span class="hljs-variable">$result</span>, function(<span class="hljs-variable">$a</span>, <span class="hljs-variable">$b</span>) <span class="hljs-keyword">use</span> ($<span class="hljs-title">key</span>) { <span class="hljs-title">return</span> <span class="hljs-title">strcmp</span>($<span class="hljs-title">a</span>-&gt;{$<span class="hljs-title">key</span>}, $<span class="hljs-title">b</span>-&gt;{$<span class="hljs-title">key</span>}); });
    }
    <span class="hljs-keyword">return</span> <span class="hljs-variable">$result</span>;
}
</code></pre>
