    <div class="s-prose js-post-body" itemprop="text">
<p>You can use <a href="https://github.com/ihor/Nspl#sortedsequence-reversed--false-key--null-cmp--null" rel="nofollow">sorted</a> function from <a href="https://github.com/ihor/Nspl" rel="nofollow">Nspl</a>:</p>

<pre class="lang-php s-code-block"><code data-highlighted="yes" class="hljs language-php"><span class="hljs-keyword">use</span> <span class="hljs-keyword">function</span> \<span class="hljs-title">nspl</span>\<span class="hljs-title">a</span>\<span class="hljs-title">sorted</span>;
<span class="hljs-keyword">use</span> <span class="hljs-keyword">function</span> \<span class="hljs-title">nspl</span>\<span class="hljs-title">op</span>\<span class="hljs-title">propertyGetter</span>;
<span class="hljs-keyword">use</span> <span class="hljs-keyword">function</span> \<span class="hljs-title">nspl</span>\<span class="hljs-title">op</span>\<span class="hljs-title">methodCaller</span>;

<span class="hljs-comment">// Sort by property value</span>
<span class="hljs-variable">$sortedByCount</span> = <span class="hljs-title function_ invoke__">sorted</span>(<span class="hljs-variable">$objects</span>, <span class="hljs-title function_ invoke__">propertyGetter</span>(<span class="hljs-string">'count'</span>));

<span class="hljs-comment">// Or sort by result of method call</span>
<span class="hljs-variable">$sortedByName</span> = <span class="hljs-title function_ invoke__">sorted</span>(<span class="hljs-variable">$objects</span>, <span class="hljs-title function_ invoke__">methodCaller</span>(<span class="hljs-string">'getName'</span>));
</code></pre>
    </div>
